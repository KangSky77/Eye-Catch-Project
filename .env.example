# Eye-Catch local configuration example
# Copy this file to `.env` and edit values for your machine.

# Database
DB_HOST=localhost
DB_NAME=eyecatch_db
DB_USER=postgres
DB_PASSWORD=
DB_PORT=5432

# Cataract model
MODEL_PATH=cataract_resnet18_v3.pth

# Runtime thresholds
# Cataract risk threshold in percent. Keep this in sync with training/evaluation reports.
RISK_THRESHOLD=50.0
# Minimum MTCNN face confidence used before cropping eyes from a face photo.
FACE_PROB_THRESHOLD=0.95
# Cosine similarity threshold for the eye/non-eye validator.
EYE_SIM_THRESHOLD=0.55

# Upload limits
MAX_UPLOAD_SIZE_BYTES=10485760

# Ollama / Gemma
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=gemma4:e4b-it-qat
OLLAMA_TIMEOUT_SECONDS=120

# Optional: Kakao Local REST API key for Korean clinic search.
KAKAO_REST_KEY=

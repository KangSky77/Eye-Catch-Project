# 파이썬 캐시
__pycache__/
*.py[cod]

# 가상환경 (용량이 커서 올리면 안 됩니다)
.venv/
venv/

# 데이터셋 (수천 장의 사진을 올리면 깃허브가 거부합니다)
dataset/

# 대용량 모델 파일 (100MB 넘으면 에러 날 수 있음)
# 나중에 팀원에게는 따로 전달하거나 Git LFS를 써야 합니다.
*.pth

# 환경변수 (DB 비밀번호 등 비밀 정보 — 절대 깃에 올리면 안 됩니다)
.env

# 외부 실행파일 / 로그
ngrok.exe
train_log.txt
train_log_old.txt
train_log_v2.txt

# 임시 파일
_*.jpg
_*.png
_*.pdf

# 런타임 로그
*.log

# Node (Tailwind 빌드용) — 빌드 결과물(static/tailwind.css)은 추적, 의존성 폴더는 제외
node_modules/

# Codex/Antigravity 버전 비교용 참고자료 (실제 앱 코드 아님, 로컬 보관용)
compare/

# AI 코딩 도구 로컬 설정/백업 (개인 환경 전용)
.claude/
.claude-memory-backup/
.codex/
.agents/